generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  Novyi
  NeedsClarification
  Perspektive
  LowPotential
  VRoboti
  DomovlenoProZamir
  OchikuyePeredoplatu
  Zakryto
  Vidhyleno
}

enum ManagerRole {
  manager
  supermanager
}

enum FunnelStage {
  Zayavka
  KontaktMenedzhera
  Ugoda
}

model Lead {
  id                 Int          @id @default(autoincrement())
  instagram_id       String       @unique
  instagram_name     String?
  instagram_username String?
  phone              String?
  location           String?
  has_project        Boolean?
  type               String?
  dimensions         String?
  style              String?
  materials          String?
  budget             String?
  price_per_sqm      String?
  timeline           String?
  wishes             String?
  status             LeadStatus   @default(Novyi)
  has_application    Boolean      @default(false)
  status_history     Json?

  messages       Message[]
  notes          Note[]
  reminders      Reminder[]
  history        History[]
  leadManagers   LeadManager[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id              Int      @id @default(autoincrement())
  text            String?
  sender_id       String
  role            String   // user / bot / manager
  attachment_url  String?
  attachment_type String?  // image, video, file, audio
  timestamp       DateTime @default(now())
  lead_id         Int
  lead            Lead     @relation(fields: [lead_id], references: [id])
}

model Manager {
  id          Int          @id @default(autoincrement())
  telegram_id String       @unique
  name        String?
  role        ManagerRole  @default(manager)
  leads       LeadManager[]
}

model LeadManager {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  manager_id Int
  lead       Lead     @relation(fields: [lead_id], references: [id])
  manager    Manager  @relation(fields: [manager_id], references: [id])
  assignedAt DateTime @default(now())

  @@unique([lead_id, manager_id])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Note {
  id        Int      @id @default(autoincrement())
  text      String
  lead_id   Int
  lead      Lead     @relation(fields: [lead_id], references: [id])
  createdAt DateTime @default(now())
}

model Reminder {
  id        Int      @id @default(autoincrement())
  time      DateTime
  status    String   @default("pending")
  lead_id   Int
  lead      Lead     @relation(fields: [lead_id], references: [id])
  createdAt DateTime @default(now())
}

model History {
  id           Int          @id @default(autoincrement())
  action       String
  funnel_stage FunnelStage?
  lead_id      Int
  lead         Lead         @relation(fields: [lead_id], references: [id])
  createdAt    DateTime     @default(now())
}
