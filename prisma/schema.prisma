// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id              Int       @id @default(autoincrement())
  instagram_id    String    @unique
  instagram_name  String?
  instagram_username String?
  type            String?   // table/wardrobe
  dimensions      String?
  style           String?
  materials       String?
  budget          String?
  timeline        String?
  wishes          String?
  ai_status       AiStatus?
  status_history  Json?
  
  messages        Message[]
  notes           Note[]
  reminders       Reminder[]
  history         History[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum AiStatus {
  Perspektive
  NeedsClarification
  LowPotential
}

model Message {
  id          Int      @id @default(autoincrement())
  text        String
  sender_id   String
  role        String   // user/bot
  timestamp   DateTime @default(now())
  lead_id     Int
  lead        Lead     @relation(fields: [lead_id], references: [id])
}

model Manager {
  id          Int      @id @default(autoincrement())
  telegram_id String   @unique
  name        String?
}

model Note {
  id          Int      @id @default(autoincrement())
  text        String
  lead_id     Int
  lead        Lead     @relation(fields: [lead_id], references: [id])
  createdAt   DateTime  @default(now())
}

model Reminder {
  id          Int      @id @default(autoincrement())
  time        DateTime
  status      String   @default("pending") // pending, sent
  lead_id     Int
  lead        Lead     @relation(fields: [lead_id], references: [id])
  createdAt   DateTime  @default(now())
}

model History {
  id          Int      @id @default(autoincrement())
  action      String
  lead_id     Int
  lead        Lead     @relation(fields: [lead_id], references: [id])
  createdAt   DateTime  @default(now())
}
